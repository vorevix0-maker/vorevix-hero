{
  "redirects": [
    {
      "source": "/services/web-development",
      "destination": "/services/web-development-services",
      "permanent": true
    },
    {
      "source": "/services/ui-ux-design",
      "destination": "/services/ui-ux-design-services",
      "permanent": true
    },
    {
      "source": "/services/web-design-australia",
      "destination": "/australia/web-design",
      "permanent": true
    },
    {
      "source": "/services/web-development-australia",
      "destination": "/australia/web-development",
      "permanent": true
    },
    {
      "source": "/services/ui-ux-design-services-australia",
      "destination": "/australia/ui-ux-design",
      "permanent": true
    },
    {
      "source": "/services/seo-services-australia",
      "destination": "/australia/seo-services",
      "permanent": true
    },
    {
      "source": "/services/branding-australia",
      "destination": "/australia/branding-services",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).(js|css|png|jpg|jpeg|webp|svg|ico|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
